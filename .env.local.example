NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 2: Member Lifecycle
# Google Cloud Console → APIs & Services → Credentials
# Enable "Places API (New)" and "Geocoding API" on the key.
# If unset, address fields gracefully degrade to plain text input.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Phase 5: Monetization — Stripe (test mode)
# Get these from dashboard.stripe.com → Developers → API keys.
# STRIPE_WEBHOOK_SECRET is returned by Stripe when you register the
# /api/webhooks/stripe endpoint. All three live on Vercel only — never
# commit real values.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
